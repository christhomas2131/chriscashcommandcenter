# ── Database ──────────────────────────────────────────────────────────────────
# Postgres connection string.  On Render, copy from your Postgres service's
# "Internal Database URL" (starts with postgresql://).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── App behaviour ─────────────────────────────────────────────────────────────
APP_ENV=development          # set to "production" on Render

# Set to "true" to seed sample data on first startup (local dev only).
# Leave unset or "false" in production.
SEED_ON_STARTUP=true

# ── Job ingestion APIs ────────────────────────────────────────────────────────
JSEARCH_API_KEY=your_rapidapi_key_here
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
USAJOBS_EMAIL=your_email@example.com
USAJOBS_API_KEY=your_usajobs_api_key

# Path to search_config.json (default works for local dev)
# INGESTION_SEARCH_CONFIG=job-scraper/search_config.json
